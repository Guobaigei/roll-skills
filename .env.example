# OpenClaw install prerequisites.
# Fill this file before starting installation, then copy it to:
# macOS: ~/.openclaw/.env
# Windows: %USERPROFILE%\.openclaw\.env
# Keep real secrets on the local machine only. Do not paste them into chat.

# Required: default model provider. Used by `qwen/qwen3.6-plus`.
QWEN_API_KEY=

# Required: fallback model provider. Used by `deepseek/deepseek-reasoner`.
DEEPSEEK_API_KEY=

# Required: Feishu bot App ID. Used by channels.feishu.accounts.main.appId.
FEISHU_APP_ID=

# Required: Feishu bot App Secret. Used by channels.feishu.accounts.main.appSecret.
FEISHU_APP_SECRET=

# Required: display name for the Feishu account in OpenClaw config.
FEISHU_BOT_NAME=OpenClaw

# Required: use `feishu` for mainland Feishu, `lark` for international Lark.
FEISHU_DOMAIN=feishu

# Optional: gateway auth token if the user wants to pin one explicitly.
OPENCLAW_GATEWAY_TOKEN=
