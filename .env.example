# OpenClaw install prerequisites.
# Fill this file before starting installation, then copy it to:
# macOS: ~/.openclaw/.env
# Windows: %USERPROFILE%\.openclaw\.env
# Keep real secrets on the local machine only. Do not paste them into chat.

# 你的 QwenKey
QWEN_API_KEY=

# 你的 DeepSeekKey
DEEPSEEK_API_KEY=

# 你的飞书 AppID
FEISHU_APP_ID=

# 你的飞书 AppSecret
FEISHU_APP_SECRET=

# OpenClaw 里显示的飞书账号名称
FEISHU_BOT_NAME=OpenClaw

# 大陆飞书填 `feishu`，国际版 Lark 填 `lark`。
FEISHU_DOMAIN=feishu

# 可选：如果用户想要固定一个 Gateway 认证 token，可以在这里填写。
OPENCLAW_GATEWAY_TOKEN=
